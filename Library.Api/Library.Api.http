@baseUrl = http://localhost:5087
@authorId = 1
@genreId = 1
@bookId = 1

### Authors

### Get all authors
GET {{baseUrl}}/authors

### Create a new author
POST {{baseUrl}}/authors
Content-Type: application/json

{
  "firstName": "Krešo",
  "lastName": "Krešić",
  "dateOfBirth": "1985-04-12",
  "biography": "Test author for API verification."
}

### Get an author by id
GET {{baseUrl}}/authors/{{authorId}}

### Update an author by id
PUT {{baseUrl}}/authors/{{authorId}}
Content-Type: application/json

{
  "firstName": "Mirko",
  "lastName": "Peric Updated",
  "dateOfBirth": "1985-04-12",
  "biography": "Updated biography for testing."
}

### Delete an author by id
DELETE {{baseUrl}}/authors/{{authorId}}

### Genres

### Get all genres
GET {{baseUrl}}/genres

### Create a new genre
POST {{baseUrl}}/genres
Content-Type: application/json

{
  "name": "Sci-Fi"
}

### Get a genre by id
GET {{baseUrl}}/genres/{{genreId}}

### Books

### Get all books
GET {{baseUrl}}/books

### Create a new book
POST {{baseUrl}}/books
Content-Type: application/json

{
  "title": "Dune",
  "isbn": "9780441013593",
  "description": "Classic science fiction novel.",
  "publisher": "Ace",
  "publishedYear": 1965,
  "pageCount": 688,
  "language": "English",
  "availableCopies": 5,
  "authorId": {{authorId}},
  "genreId": {{genreId}}
}

### Get a book by id
GET {{baseUrl}}/books/{{bookId}}

### Update a book by id
PUT {{baseUrl}}/books/{{bookId}}
Content-Type: application/json

{
  "title": "Dune Messiah",
  "isbn": "9780441172696",
  "description": "Second book in the Dune series.",
  "publisher": "Ace",
  "publishedYear": 1969,
  "pageCount": 304,
  "language": "English",
  "availableCopies": 3,
  "authorId": {{authorId}},
  "genreId": {{genreId}}
}

### Delete a book by id
DELETE {{baseUrl}}/books/{{bookId}}